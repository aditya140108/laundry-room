generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id               Int      @id @default(autoincrement())
  userID           Int
  name             String?  @db.VarChar(100)
  email            String?  @db.VarChar(255)

  bagNo            String   @unique @db.VarChar(10)

  status           Status   @default(COLLECTED)

  clothesCount     Int?     @default(0)

  lastCollectedBy  Int?
  lastSubmitted    DateTime?
  lastReady        DateTime?
  lastCollected    DateTime?
}

enum Status {
  SUBMITTED
  READY
  COLLECTED
}