generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  userID      Int      @id
  bagNo       String?  @db.VarChar(4)
  isCollected Boolean? @default(true)
  email       String? @db.VarChar(255)
  name        String? @db.VarChar(100)
  
  @@map("user")
}
